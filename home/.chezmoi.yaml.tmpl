{{- $git_email := promptStringOnce . "git_email" "Enter git email:" -}}
{{- $domain := promptStringOnce . "domain" "Enter domain:" -}}
{{- $choices := list "personal" "pro"  -}}
{{- $mode := promptChoiceOnce . "mode" "What type of host are you on" $choices -}}
{{- $should_include_secrets := promptBoolOnce . "should_include_secrets" "Should the host include secrets" -}}

data:
    git_email: {{ $git_email | quote }}
    domain: {{ $domain | quote }}
    mode: {{ $mode | quote }}
    should_include_secrets: {{ $should_include_secrets }}

scriptEnv:
    PASS_LOG_LEVEL: "error"

hooks:
  read-source-state:
    pre:
      command: {{ .chezmoi.workingTree }}/install/common/protonpass.sh

protonPass:
    command: {{ .chezmoi.destDir }}/.local/share/mise/shims/pass-cli