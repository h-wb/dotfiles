#!/bin/bash

set -euo pipefail

rootmoi_path='{{ joinPath .chezmoi.homeDir ".local/bin/scripts/rootmoi" }}'
original_args=(
  {{ rest .chezmoi.args | quoteList | join " " }}
)
args=(apply)

# Allow skipping rootmoi (e.g. NO_ROOTMOI=1 chezmoi apply)
if [[ -n "${NO_ROOTMOI:-}" ]]; then
  exit 0
fi

# Filter out args that don't apply to rootmoi
skip_one_more=false
for i in "${!original_args[@]}"; do
  if [[ "${skip_one_more}" == true ]]; then
    skip_one_more=false
    continue
  fi

  # Drop --source / -S (rootmoi has its own sourceDir)
  if [[ "${original_args[i]}" == "-S" || "${original_args[i]}" == "--source" ]]; then
    skip_one_more=true
    continue
  fi
  if [[ "${original_args[i]}" == "-S="* || "${original_args[i]}" == "--source="* ]]; then
    continue
  fi

  # Drop --apply (we always apply)
  if [[ "${original_args[i]}" == "-a" || "${original_args[i]}" == "-a="* ||
        "${original_args[i]}" == "--apply" || "${original_args[i]}" == "--apply="* ]]; then
    continue
  fi

  # Drop --init (rootmoi config is managed by chezmoi already)
  if [[ "${original_args[i]}" == "--init" ]]; then
    continue
  fi

  # Drop positional args (we always use apply)
  if [[ "${original_args[i]}" != "-"* ]]; then
    continue
  fi

  args+=("${original_args[i]}")
done

echo "[rootmoi] Applying root dotfiles..."
exec "${rootmoi_path}" "${args[@]}"
