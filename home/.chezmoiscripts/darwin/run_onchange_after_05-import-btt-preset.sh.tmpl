{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

# BetterTouchTool preset
# {{ joinPath .chezmoi.homeDir "Library/Application Support/BetterTouchTool/Default.bttpreset" | include | sha256sum }}

set -euo pipefail

preset="${HOME}/Library/Application Support/BetterTouchTool/Default.bttpreset"

if [ "${CI:-false}" = "true" ]; then
    echo "[info] skipping BTT preset import in CI"
    exit 0
fi

if [ ! -d "/Applications/BetterTouchTool.app" ]; then
    echo "[warn] BetterTouchTool not installed, skipping preset import"
    exit 0
fi

encoded=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "${preset}")
open "btt://importpreset?url=file://${encoded}"
echo "[info] imported BTT preset"
{{ end -}}
